@{
    ViewData["Title"] = "About Us";
}

<section class="about-shell">
    <div class="about-hero mb-4">
        <div class="row g-4 align-items-center">
            <div class="col-lg-7">
                <p class="about-eyebrow">Company Profile</p>
                <h1 class="about-title">Built for disciplined financial operations.</h1>
                <p class="about-copy mb-0">
                    QuantumFlow helps operating teams unify expense control, revenue visibility, and executive reporting in one workflow.
                    The platform is designed for finance-led organizations that need faster review cycles, cleaner signals, and accountable decision-making.
                </p>
            </div>
            <div class="col-lg-5">
                <div class="about-grid">
                    <article class="about-metric">
                        <span class="about-metric__value">2018</span>
                        <span class="about-metric__label">Year the company launched its finance operations platform</span>
                    </article>
                    <article class="about-metric">
                        <span class="about-metric__value">34</span>
                        <span class="about-metric__label">Cross-functional operators supported across reporting cycles</span>
                    </article>
                    <article class="about-metric">
                        <span class="about-metric__value">99.4%</span>
                        <span class="about-metric__label">Target data availability for monthly performance reviews</span>
                    </article>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <article class="about-card">
                <p class="about-card__eyebrow">Mission</p>
                <h2 class="about-card__title h4">Clear reporting, faster action.</h2>
                <p class="about-card__copy mb-0">
                    We focus on reducing the lag between financial signals and operational decisions so leadership teams can respond with confidence.
                </p>
            </article>
        </div>
        <div class="col-lg-4">
            <article class="about-card">
                <p class="about-card__eyebrow">What We Do</p>
                <h2 class="about-card__title h4">Operational finance, not static dashboards.</h2>
                <ul class="about-list">
                    <li>Surface current revenue, spend, and variance data in a single review workspace.</li>
                    <li>Support department leaders with consistent reporting structures and faster drill-downs.</li>
                    <li>Give finance teams a cleaner path from exceptions to action plans.</li>
                </ul>
            </article>
        </div>
        <div class="col-lg-4">
            <article class="about-card">
                <p class="about-card__eyebrow">Contact</p>
                <h2 class="about-card__title h4">Reach the QuantumFlow team.</h2>
                <p class="about-card__copy mb-2">General inquiries: hello@quantumflow.local</p>
                <p class="about-card__copy mb-2">Support desk: support@quantumflow.local</p>
                <p class="about-card__copy mb-0">Headquarters: 88 Meridian Plaza, Suite 500, Austin, TX</p>
            </article>
        </div>
    </div>
</section>